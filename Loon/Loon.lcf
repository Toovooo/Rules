[General]
ip-mode = dual
ipv6-vif = off
dns-server = system
sni-sniffing = true
disable-stun = false
dns-reject-mode = LoopbackIP
domain-reject-mode = DNS
udp-fallback-mode = REJECT
wifi-access-http-port = 7222
wifi-access-socks5-port = 7221
allow-wifi-access = false
interface-mode = auto
test-timeout = 2
disconnect-on-policy-change = false
switch-node-after-failure-times = 3
internet-test-url = http://connectivitycheck.platform.hicloud.com/generate_204
proxy-test-url = http://www.gstatic.com/generate_204
resource-parser = https://raw.githubusercontent.com/sub-store-org/Sub-Store/release/sub-store-parser.loon.min.js
geoip-url = https://raw.githubusercontent.com/NobyDa/geoip/release/Private-GeoIP-CN.mmdb
ipasn-url = https://geodata.kelee.one/GeoLite2-ASN-P3TERX.mmdb
skip-proxy = www.baidu.com,yunbusiness.ccb.com,wxh.wo.cn,gate.lagou.com,www.abchina.com.cn,www.shanbay.com,login-service.mobile-bank.psbc.com,mobile-bank.psbc.com,id6.me
real-ip = easy-login.10099.com.cn,*-update.xoyocdn.com,id6.me,open.e.189.cn
skip-first-packet = server.ovital.com:443
bypass-tun = 10.0.0.0/8, 100.64.0.0/10, 127.0.0.0/8, 169.254.0.0/16, 172.16.0.0/12, 192.0.0.0/24, 192.0.2.0/24, 192.88.99.0/24, 192.168.0.0/16, 198.51.100.0/24, 203.0.113.0/24, 224.0.0.0/4, 255.255.255.255/32

[Host]

[Proxy]

[Remote Proxy]

[Remote Filter]
US = NameRegex, FilterKey = "(?i)(美|US|United States|America)"
HK = NameRegex, FilterKey = "(?i)(港|HK|Hong)"
TW = NameRegex, FilterKey = "(?i)(台|TW|Tai)"
JP = NameRegex, FilterKey = "(?i)(日本|川日|东京|大阪|泉日|埼玉|沪日|深日|JP|Japan)"
KR = NameRegex, FilterKey = "(?i)(KR|Korea|KOR|首尔|韩|韓)"
SG = NameRegex, FilterKey = "(?i)(新加坡|坡|狮城|SG|Singapore)"
XX = NameRegex, FilterKey = ".*"
VV = NameRegex, FilterKey = "(?i)(CDN|0x)"

[Proxy Group]
UnitedStates = select, US, img-url = https://github.com/Toovooo/Rules/raw/master/Icon/Color/UnitedStates.png
HongKong = select, HK, img-url = https://github.com/Toovooo/Rules/raw/master/Icon/Color/HongKong.png
Japan = select, JP, img-url = https://github.com/Toovooo/Rules/raw/master/Icon/Color/Japan.png
Korea = select, KR, img-url = https://github.com/Toovooo/Rules/raw/master/Icon/Color/Korea.png
Global = select, XX, img-url = https://github.com/Toovooo/Rules/raw/master/Icon/Color/Global.png
Singapore = select, SG, img-url = https://github.com/Toovooo/Rules/raw/master/Icon/Color/Singapore.png
Streaming = select, UnitedStates, HongKong, Japan, Korea, Global, Singapore, DIRECT, img-url = https://github.com/Toovooo/Rules/raw/master/Icon/Color/Streaming.png
Apple = select, DIRECT, UnitedStates, HongKong, Japan, Korea, Global, Singapore, img-url = https://github.com/Toovooo/Rules/raw/master/Icon/Color/Apple.png
Spotify = select, UnitedStates, HongKong, Japan, Korea, Global, Singapore, img-url = https://github.com/Toovooo/Rules/raw/master/Icon/Color/Spotify.png
YouTube = select, UnitedStates, HongKong, Japan, Korea, Global, Singapore, img-url = https://github.com/Toovooo/Rules/raw/master/Icon/Color/YouTube.png
Steam = select, UnitedStates, HongKong, Japan, Korea, Global, Singapore, img-url = https://github.com/Toovooo/Rules/raw/master/Icon/Color/Steam.png
Emby = select, UnitedStates, HongKong, Japan, Korea, Global, Singapore, img-url = https://github.com/Toovooo/Rules/raw/master/Icon/Color/Emby.png
Telegram = select, UnitedStates, HongKong, Japan, Korea, Global, Singapore, img-url = https://github.com/Toovooo/Rules/raw/master/Icon/Color/Telegram.png
 
[Rule]
FINAL, Streaming
 
[Remote Rule]
https://github.com/Toovooo/Rules/raw/master/Loon/Lsr/AdBlock.lsr, policy = REJECT, tag = AdBlock, enabled = true
https://github.com/Toovooo/Rules/raw/master/Loon/Lsr/Steam.lsr, policy = Steam, tag = Steam, enabled = true
https://github.com/Toovooo/Rules/raw/master/Loon/Lsr/Spotify.lsr, policy = Spotify, tag = Spotify, enabled = true
https://github.com/Toovooo/Rules/raw/master/Loon/Lsr/Telegram.lsr, policy = Telegram, tag = Telegram, enabled = true
https://github.com/Toovooo/Rules/raw/master/Loon/Lsr/YouTube.lsr, policy = YouTube, tag = YouTube, enabled = true
https://github.com/Toovooo/Rules/raw/master/Loon/Lsr/Streaming.lsr, policy = Streaming, tag = Streaming, enabled = true
https://github.com/Toovooo/Rules/raw/master/Loon/Lsr/Apple.lsr, policy = Apple, tag = Apple, enabled = true
https://github.com/Toovooo/Rules/raw/master/Loon/Lsr/Epic.lsr, policy = DIRECT, tag = Epic, enabled = true
https://github.com/Toovooo/Rules/raw/master/Loon/Lsr/Emby.lsr, policy = Emby, tag = Emby, enabled = true
https://github.com/Toovooo/Rules/raw/master/Loon/Lsr/Geoip.lsr, policy = DIRECT, tag = China, enabled = true

[Rewrite]

[Script]
generic script-path=https://github.com/Toovooo/Rules/raw/master/Script/Check/NetworkEntryAndExitQueries.js, timeout=10, tag=入口落地查询,img-url=globe.asia.australia.system
generic script-path=https://github.com/Toovooo/Rules/raw/master/Script/Check/LocationDetection.js, timeout=10, tag=地理位置查询,img-url=location.circle.system
generic script-path=https://github.com/Toovooo/Rules/raw/master/Script/Check/NodeUnlockDetection.js, timeout=20, tag=节点解锁查询,img-url=play.circle.system

[Plugin]
https://github.com/Toovooo/Rules/raw/master/Loon/Lpx/AdBlock.lpx, enabled = true
https://github.com/Toovooo/Rules/raw/master/Loon/Lpx/Spotify.lpx, enabled = true
https://github.com/Toovooo/Rules/raw/master/Loon/Lpx/Youtube.lpx, enabled = true
https://github.com/Toovooo/Rules/raw/master/Loon/Lpx/WeatherKit.lpx, enabled = true
https://github.com/Toovooo/Rules/raw/master/Loon/Lpx/Tieba.lpx, enabled = true
https://github.com/Toovooo/Rules/raw/master/Loon/Lpx/BoxJs.lpx, policy = Final, enabled = true

[MITM]
hostname =
ca-p12 = 
ca-passphrase = 
skip-server-cert-verify = false
